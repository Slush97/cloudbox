# Required
DATABASE_URL=postgres://silo:silo@localhost:5432/silo
JWT_SECRET=  # generate with: openssl rand -hex 32

# Storage
STORAGE_PATH=./data

# Optional: S3 backend (omit to use local filesystem)
# S3_ENDPOINT=http://localhost:9000
# S3_BUCKET=silo

# Optional: CORS origin (omit for same-origin, set to * for dev)
# CORS_ORIGIN=http://localhost:8080

# Optional: max upload size in bytes (default: 10GB)
# MAX_UPLOAD_BYTES=10737418240

# Server
SILO_HOST=0.0.0.0
SILO_PORT=3000

# Production only (for Caddy auto-TLS)
# DOMAIN=photos.example.com
# DB_PASSWORD=changeme
