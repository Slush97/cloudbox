# Required
DATABASE_URL=postgres://cloudbox:cloudbox@localhost:5432/cloudbox
JWT_SECRET=  # generate with: openssl rand -hex 32

# Storage
STORAGE_PATH=./data
MODELS_PATH=./models

# Optional: S3 backend (omit to use local filesystem)
# S3_ENDPOINT=http://localhost:9000
# S3_BUCKET=cloudbox

# Optional: CORS origin (omit for same-origin, set to * for dev)
# CORS_ORIGIN=http://localhost:8080

# Optional: max upload size in bytes (default: 10GB)
# MAX_UPLOAD_BYTES=10737418240

# Server
CLOUDBOX_HOST=0.0.0.0
CLOUDBOX_PORT=3000
